        <mxCell id="AsfBcCdLAqqEViXDGGea-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;What is generative AI?&lt;br&gt;Why we use Gen AI?&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="360" x="220" y="40" as="geometry" />
        </mxCell>
        <mxCell id="AsfBcCdLAqqEViXDGGea-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Why Gen AI required?&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;b&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Automation&lt;/b&gt;&lt;/div&gt;&lt;/b&gt;&lt;b&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Faster delivary&lt;/b&gt;&lt;/div&gt;&lt;/b&gt;&lt;b&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;reduce human effor&lt;/b&gt;&lt;/div&gt;&lt;/b&gt;&lt;b&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Reduce manual error&lt;/b&gt;&lt;/div&gt;&lt;/b&gt;&lt;b&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Better productivity&lt;/b&gt;&lt;/div&gt;&lt;/b&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Cost reduction&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="370" x="220" y="210" as="geometry" />
        </mxCell>
        <mxCell id="AsfBcCdLAqqEViXDGGea-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6a00ff;fontColor=#ffffff;strokeColor=#3700CC;" value="&lt;b&gt;Differece b/w Gen AI &amp;amp; Agentic AI&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="330" x="240" y="350" as="geometry" />
        </mxCell>
        <mxCell id="AsfBcCdLAqqEViXDGGea-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Gen AI&lt;br&gt;&lt;/b&gt;&lt;span class=&quot;zlAe0W_TextBase zlAe0W_Text&quot; data-w-component=&quot;text&quot; data-w-weight=&quot;semibold&quot; data-w-inline=&quot;&quot; data-w-whitespace=&quot;linebreaks&quot;&gt;GenAI = the brain that writes.&lt;/span&gt; Great at drafting, explaining, coding, summarizing, and transforming information.&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;table&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td data-start=&quot;156&quot; data-end=&quot;170&quot; data-col-size=&quot;sm&quot;&gt;&lt;strong data-start=&quot;158&quot; data-end=&quot;169&quot;&gt;&lt;/strong&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;table&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td data-start=&quot;170&quot; data-end=&quot;216&quot; data-col-size=&quot;md&quot;&gt;&lt;b&gt;1-Creates content (text, images, code, audio)&lt;br&gt;2-Responds to prompts&lt;br&gt;3-Limited to generating outputs&lt;br&gt;4-Usually stateless or short-term context&lt;br&gt;5-Writing an email draft&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="130" width="320" x="105" y="420" as="geometry" />
        </mxCell>
        <mxCell id="AsfBcCdLAqqEViXDGGea-7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;" value="&lt;b&gt;Agentic AI&lt;br&gt;&lt;/b&gt;&lt;span class=&quot;zlAe0W_TextBase zlAe0W_Text&quot; data-w-component=&quot;text&quot; data-w-weight=&quot;semibold&quot; data-w-inline=&quot;&quot; data-w-whitespace=&quot;linebreaks&quot;&gt;Agentic AI = the brain + hands + checklist.&lt;/span&gt; It uses a GenAI model underneath, then adds planning, tool use, memory, permissions, and feedback loops to pursue an objective.&lt;b&gt;&lt;br&gt;&lt;br&gt;&lt;/b&gt;&lt;div&gt;&lt;b&gt;1-Achieves goals by planning and taking actions&lt;br&gt;2-Acts autonomously toward an objective&lt;br&gt;3-Can reason, plan, choose tools, and adapt&lt;br&gt;4-Often maintains memory and tracks progress&lt;br&gt;5-Researching a topic, drafting the email, sending it, and following up&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="420" x="440" y="420" as="geometry" />
        </mxCell>
        <mxCell id="AsfBcCdLAqqEViXDGGea-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e51400;fontColor=#ffffff;strokeColor=#B20000;" value="&lt;b&gt;GenAI Architecture&lt;/b&gt;" vertex="1">
